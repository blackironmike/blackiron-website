{
  "buildCommand": "node generate-sitemap.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    { "path": "/api/sync-leads", "schedule": "*/15 * * * *" },
    { "path": "/api/sync-members", "schedule": "0 */6 * * *" }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "blackironathletics.com"
        }
      ],
      "destination": "https://www.blackironathletics.com/:path",
      "permanent": true
    },
    { "source": "/why-creatine-is-important", "destination": "/blog/why-creatine-is-important", "permanent": true },
    { "source": "/crossfit-alternative-frisco-tx", "destination": "/blog/crossfit-alternative-frisco-tx", "permanent": true },
    { "source": "/olympic-weightlifting-frisco-tx", "destination": "/blog/olympic-weightlifting-frisco-tx", "permanent": true },
    { "source": "/hyrox-training-frisco-tx", "destination": "/blog/hyrox-training-frisco-tx", "permanent": true },
    { "source": "/best-gym-frisco-tx", "destination": "/blog/best-gym-frisco-tx", "permanent": true },
    { "source": "/strength-training-for-beginners", "destination": "/blog/strength-training-for-beginners", "permanent": true },
    { "source": "/group-fitness-vs-personal-training", "destination": "/blog/group-fitness-vs-personal-training", "permanent": true },
    { "source": "/getting-back-into-working-out", "destination": "/blog/getting-back-into-working-out", "permanent": true },
    { "source": "/what-is-xenom-decathlon-of-fitness", "destination": "/blog/what-is-xenom-decathlon-of-fitness", "permanent": true },
    { "source": "/calisthenics-training-frisco-tx", "destination": "/blog/calisthenics-training-frisco-tx", "permanent": true },
    { "source": "/blueprint", "destination": "/fuelpath", "permanent": true },
    { "source": "/blueprint-philosophy", "destination": "/fuelpath-philosophy", "permanent": true },
    { "source": "/blueprint-how-to-use", "destination": "/fuelpath-how-to-use", "permanent": true },
    { "source": "/blueprint-calendar", "destination": "/fuelpath-calendar", "permanent": true },
    { "source": "/blueprint-phase-1-maintain", "destination": "/fuelpath-phase-1-maintain", "permanent": true },
    { "source": "/blueprint-phase-2-cut", "destination": "/fuelpath-phase-2-cut", "permanent": true },
    { "source": "/blueprint-phase-3-maintain", "destination": "/fuelpath-phase-3-maintain", "permanent": true },
    { "source": "/blueprint-phase-4-build", "destination": "/fuelpath-phase-4-build", "permanent": true },
    { "source": "/blueprint-supplements", "destination": "/fuelpath-supplements", "permanent": true },
    { "source": "/blueprint-decade", "destination": "/fuelpath-decade", "permanent": true },
    { "source": "/blueprint-dashboard", "destination": "/fuelpath-dashboard", "permanent": true },
    { "source": "/blueprint-admin", "destination": "/fuelpath-admin", "permanent": true },
    { "source": "/fuelpath-tracker", "destination": "/fuelpath-dashboard", "permanent": false },

    { "source": "/images/logo.png", "destination": "/images/logos/logo.png", "permanent": true },
    { "source": "/images/black-iron-athletics-logo.png", "destination": "/images/logos/black-iron-athletics-logo.png", "permanent": true },
    { "source": "/images/Anvil-BLACK.png", "destination": "/images/logos/Anvil-BLACK.png", "permanent": true },
    { "source": "/images/Anvil-WHITE.png", "destination": "/images/logos/Anvil-WHITE.png", "permanent": true },
    { "source": "/images/fuel-path-logo.png", "destination": "/images/logos/fuel-path-logo.png", "permanent": true },
    { "source": "/images/Fuel-Path-Anvil-Banner.png", "destination": "/images/logos/Fuel-Path-Anvil-Banner.png", "permanent": true },
    { "source": "/images/FuelPath-Box%20Logo.png", "destination": "/images/logos/FuelPath-Box%20Logo.png", "permanent": true },
    { "source": "/images/email-header.jpg", "destination": "/images/email/email-header.jpg", "permanent": true },
    { "source": "/images/email-signature-mike.png", "destination": "/images/email/email-signature-mike.png", "permanent": true },
    { "source": "/images/iron-will-banner.png", "destination": "/images/email/iron-will-banner.png", "permanent": true },
    { "source": "/images/xenon-event-banner.png", "destination": "/images/email/xenon-event-banner.png", "permanent": true },
    { "source": "/images/owner-headcoach-mike.webp", "destination": "/images/team/owner-headcoach-mike.webp", "permanent": true },
    { "source": "/images/hero-main.webp", "destination": "/images/heroes/hero-main.webp", "permanent": true },
